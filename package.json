{
  "scripts": {
    "test": "node --test 'tests/unit/**/*.test.js'",
    "dashboard": "node scripts/dashboard/server.js",
    "demo": "node scripts/scratch/orchestrator.js",
    "demo:from:script": "node scripts/scratch/orchestrator.js --from=script",
    "demo:from:build": "node scripts/scratch/orchestrator.js --from=build",
    "demo:from:record": "node scripts/scratch/orchestrator.js --from=record",
    "demo:from:post-process": "node scripts/scratch/orchestrator.js --from=post-process",
    "demo:from:voiceover": "node scripts/scratch/orchestrator.js --from=voiceover",
    "demo:from:resync-audio": "node scripts/scratch/orchestrator.js --from=resync-audio",
    "demo:from:embed-sync": "node scripts/scratch/orchestrator.js --from=embed-sync",
    "resync-audio": "PIPELINE_RUN_DIR=$(cat out/latest/.rundir 2>/dev/null || echo out) node scripts/resync-audio.js",
    "embed-sync": "PIPELINE_RUN_DIR=$(cat out/latest/.rundir 2>/dev/null || echo out) node scripts/embed-sync.js",
    "demo:from:render": "node scripts/scratch/orchestrator.js --from=render",
    "demo:no-touchup": "node scripts/scratch/orchestrator.js --no-touchup",
    "studio": "remotion studio",
    "studio:demo": "node -e \"const p=require('path'),fs=require('fs'),cp=require('child_process');const d=fs.readFileSync('out/latest/.rundir','utf8').trim();const pf=p.join(d,'remotion-props.json');const args=['remotion','studio','remotion/index.js'];if(fs.existsSync(pf))args.push('--props='+pf);cp.spawn('npx',args,{stdio:'inherit',shell:true}).on('error',e=>console.error(e))\"",
    "test:record": "node scripts/test-plaid-link-record.js",
    "test:record:fast": "SCREEN_DWELL_MS=1000 node scripts/test-plaid-link-record.js",
    "post-process": "node scripts/post-process-recording.js",
    "post-process:preview": "node scripts/post-process-recording.js --preview",
    "post-process:dry-run": "node scripts/post-process-recording.js --dry-run",
    "eval-recorder": "node scripts/start-eval-recorder.js",
    "demo:studio": "node scripts/scratch/orchestrator.js --record-mode=studio",
    "demo:studio:from:record": "node scripts/scratch/orchestrator.js --record-mode=studio --from=record",
    "demo:studio:from:build": "node scripts/scratch/orchestrator.js --record-mode=studio --from=build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@remotion/animated-emoji": "4.0.434",
    "@remotion/animation-utils": "4.0.434",
    "@remotion/cloudrun": "4.0.434",
    "@remotion/enable-scss": "4.0.434",
    "@remotion/shapes": "4.0.434",
    "@remotion/studio": "4.0.434",
    "@remotion/tailwind": "4.0.434",
    "@remotion/tailwind-v4": "4.0.434",
    "@remotion/transitions": "4.0.434",
    "google-auth-library": "^9.15.1",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.3.6"
  }
}
