# Local-only artifacts (generated, personal, or temporary)
.venv/
.venv-*/
graphify-out/
scripts/graphify-out/
inputs/*.bak.*
inputs/* copy.*
inputs/products/_backups/

# Safe-to-commit: inputs/_archive/ (intentional archive of retired monoliths)
# — no .gitignore entry is needed since it's a tracked directory.

# Demoland / Plaiderdays event media — large binaries (PPTX, PNG, audio scripts)
# kept locally for personal workstreams, not part of the demo-recorder pipeline.
Demoland-*
demoland-*

# Plaid Link recipe system (Layer 3 recorder writes here)
inputs/plaid-recipes/_backups/
tmp-recipe-harness.html

# Transient debugging artifacts (not knowledge/code/skills)
.playwright-mcp/
artifacts/
/*.png
inputs/prompt.*-backup.*
inputs/*.bak

# One-off exports (portable skills, etc.) — not part of the pipeline
exports/

# Brandfetch Brand Context API per-domain cache (regenerable; not committed)
inputs/brand-context-cache.json

# Cursor local worktree state (per-machine; never committed)
.cursor/worktrees.json
