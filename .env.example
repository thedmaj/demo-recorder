# Sample environment — copied to `.env` on first run (`bash scripts/setup/install.sh`
# when `.env` is missing). Replace placeholders with real values (request secrets from
# your repo owner). Never commit `.env`.

STEEL_API_KEY=your_steel_api_key_here
# FIGMA_API_KEY is not used. Figma MCP authentication is handled via OAuth.
DEMO_URL=https://plaid.coastdemo.com/share/...

ANTHROPIC_API_KEY=sk-ant-api03-...

ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_192

SCRATCH_AUTO_APPROVE=false

PLAID_CLIENT_ID=
PLAID_SANDBOX_SECRET=
CRA_CLIENT_ID=
CRA_SECRET=
PLAID_LINK_CRA_CUSTOMIZATION=default
PLAID_ENV=sandbox
PLAID_LINK_LIVE=true

RECORDING_FPS=60

QA_PASS_THRESHOLD=88
MAX_REFINEMENT_ITERATIONS=5
PLAID_LINK_QA_MODE=token-only
BUILD_QA_PLAID_MODE=token-only

PLAID_LINK_CUSTOMIZATION=

MANUAL_RECORD=false
FIGMA_REVIEW=false

BRANDFETCH_API_KEY=
BRANDFETCH_CLIENT_ID=

PLAID_LAYER_TEMPLATE_ID=
CRA_LAYER_TEMPLATE=

# Glean — internal knowledge base (@gleanwork/local-mcp-server)
GLEAN_INSTANCE=
GLEAN_API_URL=https://plaid-be.glean.com
GLEAN_API_TOKEN=your_glean_token_here

# AskBill (Plaid product documentation)
ASKBILL_MCP_COMMAND=
ASKBILL_API_URL=wss://...

# Solutions Master
SOLUTIONS_MASTER_TRANSPORT=auto
SOLUTIONS_MASTER_API_URL=
SOLUTIONS_MASTER_API_KEY=
SOLUTIONS_MASTER_MCP_COMMAND=npx -y @solutions-master/mcp-server

# Vertex AI (optional embedding stages)
VERTEX_AI_PROJECT_ID=
VERTEX_AI_REGION=us-central1
GOOGLE_API_KEY=
# OAuth for Vertex / Gemini (service account). Official ADC uses a path to JSON:
GOOGLE_APPLICATION_CREDENTIALS=
# Alternatively (no file): base64-encode the entire GCP JSON key — single line in .env
# GCP_SERVICE_ACCOUNT_JSON_B64=
# Or one-line JSON (escaped \n inside private_key string): GCP_SERVICE_ACCOUNT_JSON=

# Studio / our-recorder integration
OUR_RECORDER_ROOT=
OUR_RECORDER_PROJECT=my-video
REMOTION_POINTER_ONLY=true

# Central artifact repo — HTTPS works without SSH keys; use a PAT when git prompts.
# GitHub Enterprise host for `gh` / identity (optional if using HTTPS remotes only).
PLAID_GHE_HOSTNAME=github.plaid.com
PLAID_DEMO_APPS_REPO=https://github.plaid.com/dmajetic/plaid-demo-apps

PIPELINE_WITH_SLIDES=false
BUILD_SLIDES_STRATEGY=post-agent
RESEARCH_MODE=gapfill
CLAIM_CHECK_STRICT=false

PIPE_AGENT_MODE=1
