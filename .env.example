# Existing pipeline
STEEL_API_KEY=your_steel_api_key_here
DEMO_URL=https://plaid.coastdemo.com/share/...

# AI / Claude
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs (voice generation)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb   # George (default)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Glean (internal company knowledge)
GLEAN_API_URL=https://plaid.glean.com
GLEAN_API_TOKEN=your_glean_token_here

# AskBill (Plaid product documentation)
# Preferred: MCP command (matches Cursor MCP-style integration)
# Example (local stdio server): /path/to/python /path/to/askbill_mcp_server.py
# Example (websocket bridge): npx -y mcp-remote "wss://your-askbill-host/mcp"
ASKBILL_MCP_COMMAND=
# Optional convenience fallback: if this is ws:// or wss://, the app auto-bridges via mcp-remote
ASKBILL_API_URL=wss://...

# Pipeline behavior
SCRATCH_AUTO_APPROVE=false          # Set true to skip all human review pauses
QA_PASS_THRESHOLD=88                # 0-100 score required to pass QA without refinement.
                                    # Was 80 prior to the hyper-realism upgrade ("fine enough");
                                    # bumped to 88 (polished). Set 80 to opt back into the legacy bar.
MAX_REFINEMENT_ITERATIONS=5         # Max refinement cycles (LLM regen OR agent edits). Was 3;
                                    # bumped to 5 since tokens are not a constraint.

# Research mode (gapfill | broad | deep | messaging | skip).
# Default: broad (was gapfill prior to the hyper-realism upgrade). Tokens
# are not a constraint here; broader research yields more grounded sample
# data, real Gong color, and stronger scenario-specific context. Set to
# gapfill to opt back into the shallow default. CLI flag `--research=` and
# `Research depth: <mode>` line in inputs/prompt.txt both override this.
RESEARCH_MODE=broad

# Default refinement loop when running under an AI agent (Claude Code / Cursor).
# When PIPE_AGENT_MODE=1, the orchestrator pauses on a continue-gate after each
# failed build-qa, hands the agent a per-step task .md (qa-touchup-task.md), and
# the agent makes surgical StrReplace edits. NO LLM rebuilds happen on refinement
# passes — the loop runs at most MAX_REFINEMENT_ITERATIONS or until QA passes.
# Set to 0 to fall back to the legacy LLM regen path. install.sh sets this to 1
# by default for SE setups.
PIPE_AGENT_MODE=1

# Plaid Link customization
# Non-CRA flows (Auth, funding, etc.)
PLAID_LINK_CUSTOMIZATION=
# CRA flows only (Base Report / Income Insights)
# NOTE: variable name intentionally matches pipeline expectation.
PLAID_LINK_CRA_CUSTOMIZAATION=
